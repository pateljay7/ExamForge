DATABASE_URL="postgresql://postgres:postgres@localhost:5432/exam_portal?schema=public"

# From `claude setup-token`. CLAUDE_OAUTH_TOKEN is also accepted and mapped to this.
CLAUDE_CODE_OAUTH_TOKEN=""

# Google Gemini — required only if a user selects the Gemini provider.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Secret used to sign auth tokens — change this in production.
JWT_SECRET="dev-secret-change-me"

PORT=3001
